# ============================================================================
# Terraform Variables Example
# ============================================================================
# Copy this file to terraform.tfvars and update with your values.

# AWS Configuration
# aws_region  = "ap-northeast-1"
# environment = "dev"

# VPC Configuration
# vpc_cidr             = "192.168.0.0/16"
# public_subnet_cidrs  = ["192.168.1.0/24", "192.168.2.0/24"]
# private_subnet_cidrs = ["192.168.10.0/24", "192.168.11.0/24"]
# availability_zones   = ["ap-northeast-1a", "ap-northeast-1c"]

# VPN Configuration
# vpn_client_cidr_pc        = "172.16.0.0/22"
# vpn_client_cidr_mobile    = "172.17.0.0/22"
# vpn_session_timeout_hours = 8

# IAM Identity Center - VPN接続を許可するユーザーIDのリスト
vpn_user_ids = [
  # "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
]

# Certificate Configuration
organization_name = "YourOrganization"
vpn_domain        = "vpn.example.com"

# Logging Configuration
# log_retention_days   = 90
# enable_vpc_flow_logs = true
